{
  "app": {
    "name": "IP-TV Channel Manager",
    "version": "1.0.0",
    "author": "TZY"
  },
  "network": {
    "timeout": 10,
    "max_retries": 3,
    "retry_delay": 1,
    "max_workers": 20,
    "request_headers": {
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/100.0.0.0 Safari/537.36"
    }
  },
  "logging": {
    "level": "INFO",
    "file_path": "logs/app.log",
    "max_bytes": 10485760,
    "backup_count": 5
  },
  "deduplication": {
    "by_name": true,
    "by_url": true,
    "by_group": false,
    "by_tvg_id": true,
    "keep_higher_quality": true
  },
  "quality": {
    "timeout": 5,
    "max_workers": 10
  },
  "output": {
    "m3u_file": "output/iptv.m3u",
    "txt_file": "output/channels.txt"
  },
  "channels": {
    "categories": {
      "CCTV": ["CCTV1", "CCTV2", "CCTV3", "CCTV4", "CCTV5", "CCTV5+", "CCTV6", "CCTV7", "CCTV8", "CCTV9", "CCTV10", "CCTV11", "CCTV12", "CCTV13", "CCTV14", "CCTV15", "CCTV16", "CCTV17"],
      "卫视": ["北京卫视", "东方卫视", "浙江卫视", "江苏卫视", "湖南卫视", "广东卫视", "山东卫视", "四川卫视", "河南卫视", "安徽卫视", "辽宁卫视", "黑龙江卫视", "天津卫视", "深圳卫视"]
    },
    "name_mappings": {
      "CCTV1": ["CCTV-1", "CCTV-1 HD", "CCTV1 综合", "CCTV-1 综合"],
      "CCTV2": ["CCTV-2", "CCTV-2 HD", "CCTV2 财经", "CCTV-2 财经"],
      "CCTV3": ["CCTV-3", "CCTV-3 HD", "CCTV3 综艺", "CCTV-3 综艺"],
      "CCTV4": ["CCTV-4", "CCTV-4 HD", "CCTV4 中文国际", "CCTV-4 中文国际"],
      "CCTV5": ["CCTV-5", "CCTV-5 HD", "CCTV5 体育", "CCTV-5 体育"],
